{
  "name": "kafka-message-producer",
  "version": "1.0.0",
  "description": "A web-based Kafka message producer with UI for sending single, interval, and batch messages",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "docker compose up --build producer-ui -d",
    "publish": "docker buildx build --platform linux/amd64,linux/arm64 -t rabik/kafka-message-producer:8 --push ."
  },
  "keywords": [
    "kafka",
    "producer",
    "messaging"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "kafkajs": "^2.2.4"
  }
}
